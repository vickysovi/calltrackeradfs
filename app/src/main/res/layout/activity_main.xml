<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ─── HEADER ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 Call Tracker"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"
                android:fontFamily="sans-serif-condensed"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ─── FILTER + REFRESH ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <Spinner
                android:id="@+id/spinnerFilter"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_bg"
                android:padding="8dp"
                android:popupBackground="@color/card_dark"
                android:layout_marginEnd="10dp"/>

            <Button
                android:id="@+id/btnRefresh"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="↻ Refresh"
                android:textSize="13sp"
                android:textColor="@color/bg_dark"
                android:backgroundTint="@color/accent_green"
                android:paddingHorizontal="16dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- ─── TOTAL BANNER ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_total"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL CALLS"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textColor="@color/accent_green"/>

                <TextView
                    android:id="@+id/tvTotalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL TALK TIME"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textColor="@color/accent_green"/>

                <TextView
                    android:id="@+id/tvTotalDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ─── GRID ROW 1: Incoming + Outgoing ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_incoming"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📲  INCOMING" android:textSize="11sp" android:letterSpacing="0.1"
                    android:textColor="#80FFD6"/>
                <TextView android:id="@+id/tvIncomingCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="34sp" android:textStyle="bold"
                    android:textColor="@color/text_primary" android:layout_marginTop="4dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#33FFFFFF" android:layout_marginVertical="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TALK TIME" android:textSize="10sp" android:textColor="@color/text_muted"/>
                <TextView android:id="@+id/tvIncomingDuration"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="#80FFD6" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_outgoing"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📤  OUTGOING" android:textSize="11sp" android:letterSpacing="0.1"
                    android:textColor="#80C6FF"/>
                <TextView android:id="@+id/tvOutgoingCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="34sp" android:textStyle="bold"
                    android:textColor="@color/text_primary" android:layout_marginTop="4dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#33FFFFFF" android:layout_marginVertical="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TALK TIME" android:textSize="10sp" android:textColor="@color/text_muted"/>
                <TextView android:id="@+id/tvOutgoingDuration"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="#80C6FF" android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ─── GRID ROW 2: Missed + Blocked ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_missed"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="❌  MISSED" android:textSize="11sp" android:letterSpacing="0.1"
                    android:textColor="#FFAA80"/>
                <TextView android:id="@+id/tvMissedCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="34sp" android:textStyle="bold"
                    android:textColor="@color/text_primary" android:layout_marginTop="4dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#33FFFFFF" android:layout_marginVertical="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TALK TIME" android:textSize="10sp" android:textColor="@color/text_muted"/>
                <TextView android:id="@+id/tvMissedDuration"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="#FFAA80" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_blocked"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🚫  BLOCKED" android:textSize="11sp" android:letterSpacing="0.1"
                    android:textColor="#FF8080"/>
                <TextView android:id="@+id/tvBlockedCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="34sp" android:textStyle="bold"
                    android:textColor="@color/text_primary" android:layout_marginTop="4dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#33FFFFFF" android:layout_marginVertical="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TALK TIME" android:textSize="10sp" android:textColor="@color/text_muted"/>
                <TextView android:id="@+id/tvBlockedDuration"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="#FF8080" android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ─── DAY-WISE BREAKDOWN SECTION ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_daywise"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <!-- Section Title -->
            <TextView
                android:id="@+id/tvDayWiseHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Day-Wise Breakdown"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <!-- Dynamic rows injected here -->
            <LinearLayout
                android:id="@+id/llDayWise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>

        <!-- ─── LAST UPDATED ─── -->
        <TextView
            android:id="@+id/tvLastUpdated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
